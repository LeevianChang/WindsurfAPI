# ========== Server ==========
PORT=3003
# API key for incoming requests (leave empty for open access)
API_KEY=
# Directory for persisted JSON state and logs (Docker 推荐用 /data)
DATA_DIR=

# ========== Codeium Auth ==========
# Option 1: Direct API key from Windsurf
CODEIUM_API_KEY=

# Option 2: Token from windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to the language server binary.
# Linux x64 default: /opt/windsurf/language_server_linux_x64
# Linux arm64 default: /opt/windsurf/language_server_linux_arm
# macOS Apple Silicon default: ~/.windsurf/language_server_macos_arm
# macOS Intel default: ~/.windsurf/language_server_macos_x64
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64
# Per-proxy language server data root.
# macOS local runs should use a user-writable directory, e.g. ~/.windsurf/data.
LS_DATA_DIR=/opt/windsurf/data
# gRPC port for language server
LS_PORT=42100

# ========== Dashboard ==========
# Dashboard password — protects /dashboard and all /dashboard/api/* endpoints.
# If empty AND API_KEY is also empty, dashboard is completely open (anyone can
# view accounts, API keys, logs, and trigger updates). Set this for any
# internet-facing deployment.
DASHBOARD_PASSWORD=

# Docker image used by docker-compose.yml. Set this to your own GHCR image
# after the release workflow builds it from a pushed tag, for example:
# WINDSURF_API_IMAGE=ghcr.io/leevianchang/windsurf-api:2.0.93
WINDSURF_API_IMAGE=

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info
# Enable automatic routing from claude-opus-4-7-* + thinking.type to *-thinking variants.
WINDSURFAPI_OPUS47_THINKING_UIDS=
# Disable the current account when it hits upstream rate limit. When enabled,
# the request returns 429 immediately instead of trying other accounts on the same proxy.
AUTO_DISABLE_RATE_LIMITED=

# ========== Cascade Advanced ==========
# These defaults match the code defaults. Leave them unset unless you need to tune behavior.
# Maximum output tokens sent to Cascade upstream. This is separate from MAX_TOKENS.
CASCADE_MAX_OUTPUT_TOKENS=16384
# Maximum replayed conversation history for normal Cascade models.
CASCADE_MAX_HISTORY_BYTES=400000
# Maximum replayed conversation history for 1M Cascade models.
CASCADE_1M_HISTORY_BYTES=900000
# Tool schema preamble budget. Requests over the soft limit are compacted;
# requests still over the hard limit are rejected.
TOOL_PREAMBLE_SOFT_BYTES=16000
TOOL_PREAMBLE_HARD_BYTES=32000
# Absolute upper bound for one Cascade turn. Stall timers below usually exit earlier.
CASCADE_MAX_WAIT_MS=600000
# Base no-output wait. Long prompts add 5s per ~1500 effective chars.
CASCADE_COLD_STALL_BASE_MS=30000
# No-progress wait once normal text has started.
CASCADE_WARM_STALL_MS=45000
# No-progress wait once reasoning/thinking has started.
CASCADE_WARM_STALL_THINKING_MS=120000
# No-progress wait while a Cascade tool step is active.
CASCADE_WARM_STALL_TOOL_ACTIVE_MS=180000
# How long a recent tool step keeps the tool-active stall ceiling.
CASCADE_TOOL_ACTIVE_GRACE_MS=60000
# Grace period after Cascade reports idle, used to collect final chunks.
CASCADE_IDLE_GRACE_MS=8000
# Poll interval for Cascade trajectory updates.
CASCADE_POLL_INTERVAL_MS=500

# ========== Security ==========
# Allow private/internal hosts (e.g., 192.168.x.x, 10.x.x.x, localhost) in proxy tests.
# Set to 1 for local deployments where you need to test proxies on private networks.
# Leave empty or set to 0 for public-facing deployments (default: only public hosts allowed).
ALLOW_PRIVATE_PROXY_HOSTS=
